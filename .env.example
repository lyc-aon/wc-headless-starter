# wc-headless-starter — per-environment configuration
#
# Copy to .env and fill in real values before running `docker compose up`.
# The .env file is gitignored. Never commit real credentials.
#
#   cp .env.example .env
#   # edit .env
#   ./scripts/up.sh && ./scripts/seed.sh
#
# Generating strong values:
#   openssl rand -hex 24    # for passwords

# ---- Database ----

# MySQL root password — only used during first-time volume initialization.
# Change this via MySQL if you need to rotate after the data dir exists.
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD

# Application database used by WordPress
MYSQL_DB_NAME=wordpress
MYSQL_DB_USER=wordpress
MYSQL_DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# ---- WordPress initial install ----
# These are only read by scripts/seed.sh on first install. After install
# you should rotate the admin password via wp-admin.

WP_SITE_URL=http://localhost:8099
WP_SITE_TITLE="WC Headless Starter"
WP_ADMIN_USER=admin
WP_ADMIN_PASS=CHANGE_ME_ADMIN_PASSWORD
WP_ADMIN_EMAIL=admin@wchs.local

# ---- Optional integration keys ----
# Add per-site test keys here only when a local plugin or test explicitly
# needs them. Never paste live payment provider keys into this dev file.
