{
  "name": "wc-headless-starter-spa",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync:styles": "node ../scripts/sync-spa-design-styles.mjs",
    "predev": "npm run sync:styles",
    "precheck": "npm run sync:styles",
    "prebuild": "npm run sync:styles",
    "dev": "vite dev --port 5175 --host localhost --strictPort",
    "build": "vite build",
    "preview": "vite preview --port 5175",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.15.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "svelte": "^5.15.0",
    "svelte-check": "^4.1.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.5",
    "embla-carousel": "^8.6.0",
    "ogl": "^1.0.11"
  }
}
